@version "1.2-messages" .
@prefix ex: <https://example.org/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:density-001 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "1"^^xsd:decimal ;
    qudt:unit unit:KiloGM-PER-M3
  ] .

@message .

ex:density-002 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "1"^^xsd:decimal ;
    qudt:unit unit:GM-PER-CentiM3
  ] .

@message .

ex:density-003 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "62.4279605761"^^xsd:decimal ;
    qudt:unit unit:LB_M-PER-FT3
  ] .
