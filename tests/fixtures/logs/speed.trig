@version "1.2-messages" .
@prefix ex: <https://example.org/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:speed-001 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "10"^^xsd:decimal ;
    qudt:unit unit:M-PER-SEC
  ] .

@message .

ex:speed-002 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "90"^^xsd:decimal ;
    qudt:unit unit:KiloM-PER-HR
  ] .

@message .

ex:speed-003 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "60"^^xsd:decimal ;
    qudt:unit unit:MI-PER-HR
  ] .

@message .

ex:speed-004 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "100"^^xsd:decimal ;
    qudt:unit unit:FT-PER-SEC
  ] .

@message .

ex:speed-005 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "12"^^xsd:decimal ;
    qudt:unit unit:KNOT
  ] .
