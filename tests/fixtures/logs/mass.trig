@version "1.2-messages" .
@prefix ex: <https://example.org/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:mass-001 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "5"^^xsd:decimal ;
    qudt:unit unit:KiloGM
  ] .

@message .

ex:mass-002 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "1250"^^xsd:decimal ;
    qudt:unit unit:GM
  ] .

@message .

ex:mass-003 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "250000"^^xsd:decimal ;
    qudt:unit unit:MilliGM
  ] .

@message .

ex:mass-004 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "10"^^xsd:decimal ;
    qudt:unit unit:LB_M
  ] .

@message .

ex:mass-005 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "32"^^xsd:decimal ;
    qudt:unit unit:OZ
  ] .

@message .

ex:mass-006 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "0.5"^^xsd:decimal ;
    qudt:unit unit:TON_SHORT
  ] .

@message .

ex:mass-007 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "2"^^xsd:decimal ;
    qudt:unit unit:TONNE
  ] .
