@version "1.2-messages" .
@prefix ex: <https://example.org/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:area-001 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "2"^^xsd:decimal ;
    qudt:unit unit:M2
  ] .

@message .

ex:area-002 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "25000"^^xsd:decimal ;
    qudt:unit unit:CentiM2
  ] .

@message .

ex:area-003 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "0.5"^^xsd:decimal ;
    qudt:unit unit:KiloM2
  ] .

@message .

ex:area-004 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "100"^^xsd:decimal ;
    qudt:unit unit:FT2
  ] .

@message .

ex:area-005 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "144"^^xsd:decimal ;
    qudt:unit unit:IN2
  ] .

@message .

ex:area-006 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "0.01"^^xsd:decimal ;
    qudt:unit unit:HA
  ] .

@message .

ex:area-007 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "0.25"^^xsd:decimal ;
    qudt:unit unit:AC
  ] .
