@version "1.2-messages" .
@prefix ex: <https://example.org/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:energy-001 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "1"^^xsd:decimal ;
    qudt:unit unit:J
  ] .

@message .

ex:energy-002 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "2.5"^^xsd:decimal ;
    qudt:unit unit:KiloJ
  ] .

@message .

ex:energy-003 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "0.003"^^xsd:decimal ;
    qudt:unit unit:MegaJ
  ] .

@message .

ex:energy-004 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "1"^^xsd:decimal ;
    qudt:unit unit:W-HR
  ] .

@message .

ex:energy-005 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "0.5"^^xsd:decimal ;
    qudt:unit unit:KiloW-HR
  ] .

@message .

ex:energy-006 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "100"^^xsd:decimal ;
    qudt:unit unit:CAL_IT
  ] .

@message .

ex:energy-007 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "2"^^xsd:decimal ;
    qudt:unit unit:BTU_IT
  ] .
