@version "1.2-messages" .
@prefix ex: <https://example.org/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:time-001 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "5"^^xsd:decimal ;
    qudt:unit unit:SEC
  ] .

@message .

ex:time-002 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "1500"^^xsd:decimal ;
    qudt:unit unit:MilliSEC
  ] .

@message .

ex:time-003 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "2"^^xsd:decimal ;
    qudt:unit unit:MIN
  ] .

@message .

ex:time-004 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "1.5"^^xsd:decimal ;
    qudt:unit unit:HR
  ] .

@message .

ex:time-005 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "0.25"^^xsd:decimal ;
    qudt:unit unit:DAY
  ] .

@message .

ex:time-006 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "0.02"^^xsd:decimal ;
    qudt:unit unit:WK
  ] .
