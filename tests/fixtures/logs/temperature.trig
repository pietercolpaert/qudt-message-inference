@version "1.2-messages" .
@prefix ex: <https://example.org/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:temperature-001 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "273.15"^^xsd:decimal ;
    qudt:unit unit:K
  ] .

@message .

ex:temperature-002 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "100"^^xsd:decimal ;
    qudt:unit unit:DEG_C
  ] .

@message .

ex:temperature-003 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "32"^^xsd:decimal ;
    qudt:unit unit:DEG_F
  ] .

@message .

ex:temperature-004 a ex:Observation ;
  ex:quantity [
    a qudt:QuantityValue ;
    qudt:numericValue "491.67"^^xsd:decimal ;
    qudt:unit unit:DEG_R
  ] .
