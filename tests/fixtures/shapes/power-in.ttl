@prefix ex: <https://example.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PowerInputShape a sh:NodeShape ;
  sh:targetClass ex:Observation ;
  sh:property [
    sh:path ex:quantity ;
    sh:node ex:PowerQuantityInputShape
  ] .

ex:PowerQuantityInputShape a sh:NodeShape ;
  sh:property [
    sh:path qudt:numericValue ;
    sh:datatype xsd:decimal
  ] ;
  sh:property [
    sh:path qudt:unit ;
    sh:in ( unit:W unit:KiloW unit:MegaW unit:HP )
  ] .
