@prefix ex: <https://example.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PressureInputShape a sh:NodeShape ;
  sh:targetClass ex:Observation ;
  sh:property [
    sh:path ex:quantity ;
    sh:node ex:PressureQuantityInputShape
  ] .

ex:PressureQuantityInputShape a sh:NodeShape ;
  sh:property [
    sh:path qudt:numericValue ;
    sh:datatype xsd:decimal
  ] ;
  sh:property [
    sh:path qudt:unit ;
    sh:in ( unit:PA unit:KiloPA unit:MegaPA unit:BAR unit:ATM unit:PSI )
  ] .
