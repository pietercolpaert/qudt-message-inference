@prefix ex: <https://example.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:DensityOutputShape a sh:NodeShape ;
  sh:targetClass ex:Observation ;
  sh:property [
    sh:path ex:normalizedQuantity ;
    sh:node ex:DensityQuantityOutputShape
  ] .

ex:DensityQuantityOutputShape a sh:NodeShape ;
  sh:property [
    sh:path qudt:numericValue ;
    sh:datatype xsd:decimal ;
    sh:unit unit:KiloGM-PER-M3
  ] ;
  sh:property [
    sh:path qudt:unit ;
    sh:hasValue unit:KiloGM-PER-M3
  ] .
