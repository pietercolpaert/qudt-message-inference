@prefix qcr:  <https://w3id.org/qudt-inference#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix math: <http://www.w3.org/2000/10/swap/math#> .
@prefix log:  <http://www.w3.org/2000/10/swap/log#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@prefix dt: <https://eyereasoner.github.io/eyeling/datatype#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Backward definition: the result is demanded by a forward trigger that was
# compiled from SHACL IN and SHACL OUT. The QUDT conversion convention is:
#
#   canonical = (source + sourceOffset) * sourceMultiplier
#   target    = canonical / targetMultiplier - targetOffset
#
# A shared qudt:hasDimensionVector is a mandatory guard.
qcr:convertedValue log:memoize true .
qcr:parsedCdtValue log:memoize true .

# Parse the numeric and UCUM portions of a CDT literal entirely inside Eyeling.
# The SHACL compiler supplies the accepted CDT datatypes and source-unit facts.
{
  (?literal ?datatype) qcr:parsedCdtValue (?sourceValue ?sourceUnit) .
}
<=
{
  ?literal dt:datatype ?datatype .
  ?datatype qcr:supportedCdtDatatype true .
  ?literal dt:lexicalForm ?lexicalForm .

  (?lexicalForm "^\\s*([+-]?(?:[0-9]+(?:\\.[0-9]*)?|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?)\\s+")
    string:scrape ?numericLexicalForm .
  (?lexicalForm "^\\s*[+-]?(?:[0-9]+(?:\\.[0-9]*)?|\\.[0-9]+)(?:[eE][+-]?[0-9]+)?\\s+(.+?)\\s*$")
    string:scrape ?ucumCode .
  (?numericLexicalForm xsd:double) log:dtlit ?sourceValue .

  ?sourceUnit qcr:allowedCdtSourceUnit true ;
    qcr:recognizedUcumCode ?ucumCode .
} .

{
  (?sourceValue ?sourceUnit ?targetUnit) qcr:convertedValue ?targetValue .
}
<=
{
  ?sourceUnit
    qudt:hasDimensionVector ?dimension ;
    qcr:effectiveConversionMultiplier ?sourceMultiplier ;
    qcr:effectiveConversionOffset ?sourceOffset .

  ?targetUnit
    qudt:hasDimensionVector ?dimension ;
    qcr:effectiveConversionMultiplier ?targetMultiplier ;
    qcr:effectiveConversionOffset ?targetOffset .

  (?sourceValue ?sourceOffset) math:sum ?shiftedSource .
  (?shiftedSource ?sourceMultiplier) math:product ?canonicalValue .
  (?canonicalValue ?targetMultiplier) math:quotient ?shiftedTarget .
  (?shiftedTarget ?targetOffset) math:difference ?targetValue .
} .
